<% layout("./layouts/boilerplate") %>

<div class="row mt-3">
  <div class="col-8 offset-2">
    <h3>Edit your Listing</h3>
    <form
      action="/listings/<%= listing._id %>?_method=PUT"
      method="post"
      novalidate
      class="needs-validation"
      enctype="multipart/form-data"
    >
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input
          type="text"
          name="listing[title]"
          value="<%= formData.title || listing.title %>"
          class="form-control"
          id="title"
          required
        />
        <div class="valid-feedback">Title looks good!</div>
        <div class="invalid-feedback">title is required</div>
      </div>
      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea name="listing[description]" class="form-control" required><%= formData.description || listing.description %></textarea>
        <div class="invalid-feedback">description is required</div>
      </div>
      <div class="mb-3">
        Original Listing Image <br>
        <img src="<%= originalImageUrl %>" alt="">
      </div>
      <div class="mb-3">
        <label for="image" class="form-label">Uplaod New Image</label>
        <input
          type="file"
          name="listing[image]"
          class="form-control <%= imageError ? 'is-invalid' : '' %>"
          id="image"
        />
        <% if (imageError) { %>
          <div class="invalid-feedback d-block"><%= imageError %></div>
        <% } %>
      </div>
      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="price" class="form-label">Price</label>
          <input
            type="number"
            name="listing[price]"
            value="<%= formData.price || listing.price %>"
            class="form-control"
            id="price"
            required
          />
          <div class="invalid-feedback">price is required</div>
        </div>
        <div class="mb-3 col-md-8">
          <label for="country" class="form-label">Country</label>
          <input
            type="text"
            name="listing[country]"
            value="<%= formData.country || listing.country %>"
            class="form-control"
            id="country"
            required
          />
          <div class="invalid-feedback">country is required</div>
        </div>
      </div>
      <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input
          type="text"
          name="listing[location]"
          value="<%= formData.location || listing.location %>"
          class="form-control"
          id="location"
          required
        />
        <div class="invalid-feedback">location is required</div>
      </div>
      <div class="mb-3">
          <label for="location" class="form-label">Category</label>
          <select name="listing[category]" class="form-select form-select-lg mb-3" aria-label="Large select example" required>
            <option value="trending" <%= (formData.category || listing.category) === "trending" ? "selected" : "" %>>trending</option>
            <option value="rooms" <%= (formData.category || listing.category) === "rooms" ? "selected" : "" %>>rooms</option>
            <option value="iconic cities" <%= (formData.category || listing.category) === "iconic cities" ? "selected" : "" %>>iconic cities</option>
            <option value="mountains" <%= (formData.category || listing.category) === "mountains" ? "selected" : "" %>>mountains</option>
            <option value="castles" <%= (formData.category || listing.category) === "castles" ? "selected" : "" %>>castles</option>
            <option value="amazing pools" <%= (formData.category || listing.category) === "amazing pools" ? "selected" : "" %>>amazing pools</option>
            <option value="camping" <%= (formData.category || listing.category) === "camping" ? "selected" : "" %>>camping</option>
            <option value="farms" <%= (formData.category || listing.category) === "farms" ? "selected" : "" %>>farms</option>
            <option value="arctic" <%= (formData.category || listing.category) === "arctic" ? "selected" : "" %>>arctic</option>
          </select>
          <div class="invalid-feedback">Category is required</div>
        </div>

  
      <button class="btn btn-dark edit-btn mt-3">Edit</button>
    </form>
  </div>
</div>

